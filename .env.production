# Production Environment Configuration
# Copy this file to .env.production and update with your production values

# Environment
NODE_ENV=production

# Database Configuration
DATABASE_URL="postgresql://username:password@host:5432/contentsync_prod"
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30000
DATABASE_SSL=true

# Redis Configuration
REDIS_URL="redis://username:password@host:6379"
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5000

# Authentication
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="your-super-secure-secret-key-at-least-32-characters-long-for-production"

# AI Services
GEMINI_API_KEY="your-production-gemini-api-key"

# Security
CRON_SECRET="your-super-secure-cron-secret-at-least-32-characters-long-for-production"

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=900000

# CORS Configuration
ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# Monitoring and Logging
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
LOG_LEVEL=info

# Performance
CACHE_TTL_DEFAULT=300
CACHE_TTL_USER_SESSION=3600
CACHE_TTL_PLATFORM_DATA=1800

# External Services
WEBHOOK_TIMEOUT=10000

# Platform-specific Webhook Secrets
YOUTUBE_WEBHOOK_SECRET="your-youtube-webhook-secret-for-production"
TWITTER_WEBHOOK_SECRET="your-twitter-webhook-secret-for-production"
INSTAGRAM_WEBHOOK_SECRET="your-instagram-webhook-secret-for-production"
FACEBOOK_WEBHOOK_SECRET="your-facebook-webhook-secret-for-production"
LINKEDIN_WEBHOOK_SECRET="your-linkedin-webhook-secret-for-production"
TIKTOK_WEBHOOK_SECRET="your-tiktok-webhook-secret-for-production"

# CDN Configuration (optional)
CDN_URL="https://cdn.yourdomain.com"
STATIC_ASSETS_URL="https://static.yourdomain.com"

# Email Configuration (if needed)
SMTP_HOST="smtp.yourdomain.com"
SMTP_PORT=587
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# Feature Flags
FEATURE_AI_GENERATION=true
FEATURE_WEBHOOK_PROCESSING=true
FEATURE_CONTENT_MONITORING=true
