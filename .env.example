# Database
DATABASE_URL="postgresql://username:password@localhost:5432/contentsync"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-characters-long"

# Redis (for background jobs)
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# AI Services
GEMINI_API_KEY="your-gemini-api-key"

# Security
CRON_SECRET="your-cron-secret-at-least-32-characters-long"

# Rate limiting (optional)
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900000"

# CORS (optional)
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Monitoring
SENTRY_DSN="your-sentry-dsn"

# Environment
NODE_ENV="development"

# Webhook secrets (optional - platform specific)
YOUTUBE_WEBHOOK_SECRET="your-youtube-webhook-secret"
TWITTER_WEBHOOK_SECRET="your-twitter-webhook-secret"
INSTAGRAM_WEBHOOK_SECRET="your-instagram-webhook-secret"
FACEBOOK_WEBHOOK_SECRET="your-facebook-webhook-secret"
LINKEDIN_WEBHOOK_SECRET="your-linkedin-webhook-secret"
TIKTOK_WEBHOOK_SECRET="your-tiktok-webhook-secret"